# 阿里云通义千问默认配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_MODEL=qwen-plus

# 服务配置
HOST=0.0.0.0
PORT=8000

# Docker沙箱
SANDBOX_PYTHON_IMAGE=ai-sandbox-python:latest

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 密钥加密（生产环境必填！）
# 用以下命令生成: python -c "from app.utils.crypto import generate_fernet_key; print(generate_fernet_key())"
# 用以下命令生成: python -c "from app.utils.crypto import generate_fernet_key; print(generate_fernet_key())"
FERNET_KEY=
